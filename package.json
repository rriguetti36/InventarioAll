{
  "name": "express-sqlserver-backend",
  "version": "1.0.0",
  "description": "Backend Node.js con Express y SQL Server Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:backend": "cross-env PORT=3001 nodemon server.js",
    "dev:all": "concurrently --names \"API,CLIENT\" --prefix \"[{name}]\" \"npm run dev:backend\" \"npm --prefix client run dev\"",
    "create-user": "node scripts/createUser.js"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^9.1.1",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1"
  }
}
